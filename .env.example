# ─────────────────────────────────────────────────────────────────
# TEMPLATE DE CONFIGURAÇÃO — Copa Figurinhas
# Copie este arquivo para .env.local e preencha os valores.
# No Vercel: adicione cada variável em Settings > Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── IDENTIDADE DO PROJETO ─────────────────────────────────────────
NEXT_PUBLIC_PROJECT_NAME=Convoca Kids
NEXT_PUBLIC_BASE_URL=seu_dominio.com

# ── EMAIL (Resend) ────────────────────────────────────────────────
# Acesso: https://resend.com/signup
RESEND_API_KEY=re_sua_chave_resend_aqui
EMAIL_FROM=KIDSCOPA <contato@seu_dominio.com>

# ── CHECKOUT / PREÇO ─────────────────────────────────────────────
# Acesso: https://wiapy.com ou https://kiwify.com.br
NEXT_PUBLIC_CHECKOUT_URL=https://pay.wiapy.com/seu_checkout_url
NEXT_PUBLIC_PRICE=12,90
NEXT_PUBLIC_PRICE_ORIGINAL=29,90

# ── SUPABASE ──────────────────────────────────────────────────────
# Acesso: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://seu_projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── OPENAI (gpt-image-2) ──────────────────────────────────────────
# Acesso: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-sua_chave_openai_aqui

# ── REPLICATE (remoção de fundo) ──────────────────────────────────
# Acesso: https://replicate.com/signin
REPLICATE_API_KEY=r8_sua_chave_replicate_aqui

# ── REDIS / UPSTASH (rate limit) ─────────────────────────────────
# Acesso: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://seu_banco_redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="seu_token_redis_aqui"

# ── IA — REFERÊNCIA E PROMPT ──────────────────────────────────────
AI_REFERENCE_IMAGE_FILE=jersey_reference.png
AI_PROMPT=The first image is Neymar wearing the Brazil national team jersey. The second image is a different person. Replace Neymar with the person from the second image. Keep everything else exactly the same: jersey, pose, framing, lighting and background. Preserve the exact face, skin tone, hair and age from the second image.

# ── WATERMARK ─────────────────────────────────────────────────────
NEXT_PUBLIC_WATERMARK_TEXT=CONVOCA KIDS

# ── ADMIN ────────────────────────────────────────────────────────
# Senha para acessar o painel de operações
ADMIN_SECRET=sua_senha_admin_aqui

# ── META / FACEBOOK ──────────────────────────────────────────────
# Acesso: https://business.facebook.com/events_manager
NEXT_PUBLIC_META_PIXEL_ID=seu_pixel_id_aqui
META_ACCESS_TOKEN=seu_access_token_aqui

# ── WEBHOOK WIAPY ─────────────────────────────────────────────────
# Acesso: https://wiapy.com
# URL do webhook: https://poupfacil.app.br/api/wiapy/webhook
WIAPY_WEBHOOK_SECRET=seu_token_webhook_aqui
