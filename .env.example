# ─────────────────────────────────────────────────────────────────
# TEMPLATE DE CONFIGURAÇÃO — Copa Figurinhas
# Copie este arquivo para .env.local e preencha os valores.
# No Vercel: adicione cada variável em Settings > Environment Variables
# ─────────────────────────────────────────────────────────────────

# ── IDENTIDADE DO PROJETO ─────────────────────────────────────────
NEXT_PUBLIC_PROJECT_NAME=Convoca Kids
NEXT_PUBLIC_BASE_URL=https://www.seudominio.com

# ── EMAIL (Resend) ────────────────────────────────────────────────
# Crie conta em resend.com, verifique seu domínio e gere a API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Seu Projeto <contato@seudominio.com>

# ── CHECKOUT / PREÇO ─────────────────────────────────────────────
NEXT_PUBLIC_CHECKOUT_URL=https://pay.kiwify.com.br/SEUPRODUTO
NEXT_PUBLIC_PRICE=19,90
NEXT_PUBLIC_PRICE_ORIGINAL=39,90

# ── SUPABASE ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── OPENAI (gpt-image-2) ──────────────────────────────────────────
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── REPLICATE (remoção de fundo) ──────────────────────────────────
# ATENÇÃO: a variável se chama REPLICATE_API_KEY (não TOKEN)
REPLICATE_API_KEY=r8_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── REDIS / UPSTASH (rate limit) ─────────────────────────────────
UPSTASH_REDIS_REST_URL=https://XXXXXXXX.upstash.io
UPSTASH_REDIS_REST_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── IA — REFERÊNCIA E PROMPT ──────────────────────────────────────
# Arquivo de referência em public/assets/ (substitua o arquivo também)
AI_REFERENCE_IMAGE_FILE=jersey_reference.png
# Troque "Neymar" e "Brazil national team jersey" pelo seu atleta/camisa
AI_PROMPT=The first image is Neymar wearing the Brazil national team jersey. The second image is a different person. Replace Neymar with the person from the second image. Keep everything else exactly the same: jersey, pose, framing, lighting and background. Preserve the exact face, skin tone, hair and age from the second image.

# ── WATERMARK ─────────────────────────────────────────────────────
NEXT_PUBLIC_WATERMARK_TEXT=CONVOCA KIDS

# ── ADMIN ────────────────────────────────────────────────────────
ADMIN_SECRET=SUASENHAFORTE

# ── META / FACEBOOK ──────────────────────────────────────────────
# Pixel ID — visível no Gerenciador de Eventos do Meta
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXX
# Token da API de Conversões — Meta → Events Manager → Settings → Conversions API
META_ACCESS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Opcional: código de teste para validar eventos sem contar como reais
META_TEST_EVENT_CODE=TEST00000

# ── WEBHOOK KIWIFY ────────────────────────────────────────────────
KIWIFY_WEBHOOK_SECRET=SEUTOKENWEBHOOK
